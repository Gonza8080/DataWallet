{
  "expo": {
    "name": "Nuggio",
    "slug": "nuggio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nuggio.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Nuggio uses Face ID to protect your secured nuggets and authenticate access to sensitive information.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Nuggio to access your photos.",
          "cameraPermission": "Allow Nuggio to access your camera."
        }
      ]
    ],
    "owner": "yche8888",
    "extra": {
      "eas": {
        "projectId": "d7279dcf-9ab3-4fec-ac79-0e5c2a7c8012"
      }
    }
  }
}
